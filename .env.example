# Copie a .env en la raíz del proyecto (no se sube a Git).
# Obtenga su API key en https://wandb.ai/authorize

WANDB_API_KEY=wandb_v1_REEMPLACE_CON_SU_CLAVE

# Opcional: equipo/organización en wandb.com
# WANDB_ENTITY=mi-equipo

# online (por defecto) | offline (solo carpeta local wandb/)
# WANDB_MODE=online
